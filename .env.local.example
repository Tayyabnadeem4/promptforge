# Copy this file to .env.local and add at least one provider key.
# Keys are only ever read server-side (in the API routes) — never sent to the browser.

# Anthropic — for the Claude models (Opus, Sonnet, Haiku, Fable).
# Get one at https://console.anthropic.com/settings/keys (keys start with sk-ant-).
ANTHROPIC_API_KEY=

# Groq — free, OpenAI-compatible. Powers the Llama / Gemma open models.
# Get one at https://console.groq.com/keys (keys start with gsk_).
GROQ_API_KEY=

# Secret used to sign session cookies. Set any long random string.
AUTH_SECRET=change-me-to-a-long-random-string
